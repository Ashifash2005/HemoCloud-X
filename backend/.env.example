PORT=5000
NODE_ENV=development

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET_NAME=your_bucket_name

# DynamoDB
# Uses AWS_REGION by default when DYNAMODB_REGION is not set.
DYNAMODB_REGION=us-east-1
DYNAMODB_DONORS_TABLE=bloodbank-donors-dev

# Optional SNS (future use)
# Uses AWS_REGION by default when SNS_REGION is not set.
SNS_REGION=us-east-1

# If your bucket is public, the app will create standard public URLs.
# If your bucket is private, update the S3 URL strategy (signed URLs) in code.
S3_PUBLIC_URL_BASE=

# CORS
CORS_ORIGIN=http://localhost:5173
# For multiple frontend origins, use comma-separated values.
# Example: CORS_ORIGIN=http://localhost:5173,http://192.168.1.107:5173

# Optional: donor is "available now" if lastDonationDate is older than N days.
AVAILABLE_NOW_THRESHOLD_DAYS=90

